{
  "manifest_version": 3,
  "name": "Content Upload Tracker",
  "version": "1.0.0",
  "description": "Track your content uploads across Instagram, YouTube, and LinkedIn",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["tabs", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
